{
    "name": "framerate",
    "main": "expo-router/entry",
    "version": "0.0.0",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "test": "jest",
        "deploy:ios": "eas build --platform ios --profile production --auto-submit",
        "builddev:ios": "eas build --platform ios --profile development",
        "export:web": "expo export --platform web -c",
        "lint": "biome check --error-on-warnings",
        "lint:knip": "knip",
        "typecheck": "tsc --noEmit",
        "format": "biome format --write .",
        "update:rnc": "npm install @reillymc/react-native-components@latest --save-prefix=\"~\"",
        "depcruise:modules": "depcruise src/modules --include-only '^src/modules' --collapse 3 --output-type dot | dot -T svg > docs/module-dependency-graph.svg",
        "openapi:update": "curl http://localhost:3000/api-docs/openapi.json > src/services/openapi.json",
        "openapi:generate": "rm -rf src/services/framerateBackend && openapi-generator-cli generate --generator-key typescript-fetch"
    },
    "dependencies": {
        "@expo/ui": "~56.0.18",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-native-community/netinfo": "12.0.1",
        "@react-native-segmented-control/segmented-control": "2.5.7",
        "@react-native-vector-icons/octicons": "^21.1.2",
        "@reillymc/es-utils": "^0.0.7",
        "@reillymc/react-native-components": "~0.10.0",
        "@shopify/react-native-skia": "2.6.2",
        "@tanstack/query-async-storage-persister": "^5.95.2",
        "@tanstack/react-query": "^5.95.2",
        "@tanstack/react-query-persist-client": "^5.95.2",
        "date-fns": "^4.1.0",
        "expo": "^56.0.0",
        "expo-blur": "~56.0.3",
        "expo-clipboard": "~56.0.4",
        "expo-constants": "~56.0.18",
        "expo-dev-client": "~56.0.20",
        "expo-device": "~56.0.4",
        "expo-font": "~56.0.7",
        "expo-image": "~56.0.11",
        "expo-linking": "~56.0.14",
        "expo-router": "~56.2.11",
        "expo-secure-store": "~56.0.4",
        "expo-splash-screen": "~56.0.10",
        "expo-status-bar": "~56.0.4",
        "expo-system-ui": "~56.0.5",
        "expo-web-browser": "~56.0.5",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-native": "0.85.3",
        "react-native-gesture-handler": "~2.31.1",
        "react-native-reanimated": "4.3.1",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.2",
        "react-native-svg": "15.15.4",
        "react-native-web": "^0.21.0",
        "react-native-worklets": "0.8.3",
        "victory-native": "^41.20.2"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.9",
        "@openapitools/openapi-generator-cli": "^2.31.0",
        "@testing-library/react-native": "^13.3.3",
        "@types/jest": "29.5.14",
        "@types/react": "~19.2.10",
        "dependency-cruiser": "^17.3.10",
        "jest": "~29.7.0",
        "jest-expo": "~56.0.5",
        "knip": "^6.1.0",
        "react-native-react-query-devtools": "^1.5.1",
        "typescript": "~6.0.3"
    },
    "private": true
}
